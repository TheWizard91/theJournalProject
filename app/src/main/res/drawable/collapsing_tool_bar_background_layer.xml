<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item >
        <shape android:shape="rectangle"  >
            <corners android:radius="3dip" />
            <stroke android:width="1dip" android:color="@color/darker_gray" />
            <gradient android:angle="-90"
                android:startColor="@color/darker_blue"
                android:centerColor="@color/half_blue_half_transparent"
                android:endColor="@color/mainThemeColor" />
            <corners android:topLeftRadius="32dp" android:topRightRadius="32dp" />
        </shape>
    </item>
</selector>